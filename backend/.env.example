# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/collab_engine

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password   # uncomment for auth

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX_AUTH=20        # requests per window on /api/auth/*
RATE_LIMIT_MAX_API=500        # requests per window on all other routes

# ─── Snapshot Strategy ────────────────────────────────────────────────────────
# Create a new version snapshot every N operations
SNAPSHOT_INTERVAL=50

# ─── Redis Streams ────────────────────────────────────────────────────────────
STREAM_NAME=collab:ops
STREAM_GROUP=collab-consumers
STREAM_BATCH_SIZE=100
